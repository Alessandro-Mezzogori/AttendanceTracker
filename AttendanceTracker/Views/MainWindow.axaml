<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:AttendanceTracker.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
		x:Class="AttendanceTracker.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Icon="/Assets/avalonia-logo.ico"
		Title="AttendanceTracker"
		WindowStartupLocation="CenterScreen"
		Background="{DynamicResource SystemRegionBrush}">
	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Window.Styles>
		<Style Selector="ListBoxItem">
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Margin" Value="0,0,0,12"/>
			<Setter Property="Background" Value="Transparent"/>
		</Style>

		<Style Selector="Button.danger">
			<Setter Property="Background" Value="#1AEf4444"/>
			<Setter Property="Foreground" Value="#Ef4444"/>
		</Style>
		<Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#33Ef4444"/> <Setter Property="Foreground" Value="#Ef4444"/>
		</Style>

		<Style Selector="Button.warning">
			<Setter Property="Background" Value="#1Af59e0b"/>
			<Setter Property="Foreground" Value="#f59e0b"/>
		</Style>
		<Style Selector="Button.warning:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#33f59e0b"/> <Setter Property="Foreground" Value="#f59e0b"/>
		</Style>

		<Style Selector="Button.success">
			<Setter Property="Background" Value="#1A5cb85c"/>
			<Setter Property="Foreground" Value="#5cb85c"/>
		</Style>
		<Style Selector="Button.success:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#335cb85c"/> <Setter Property="Foreground" Value="#5cb85c"/>
		</Style>
	</Window.Styles>

	<DockPanel>
		<Border DockPanel.Dock="Top"
				Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
				BorderBrush="{DynamicResource SystemControlBaseLowAcrylicElementBrush}"
				BorderThickness="0,0,0,1">
			<Menu Padding="8,4">
				<MenuItem Header="_File">
					<MenuItem Header="_Import excel..." Click="ImportExcel_Click"/>
				</MenuItem>
			</Menu>
		</Border>


		<TabControl x:Name="MainTabs" SelectionChanged="TabControl_SelectionChanged">
			<TabItem Header="Lessons">
				<ScrollViewer>
					<StackPanel Spacing="20">
						<StackPanel Spacing="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,20,0" VerticalAlignment="Center">
							<Button Content="Select Date Range">
								<Button.Flyout>
									<Flyout Placement="Bottom" Closed="FilterCalendar_SelectedDatesChanged">
										<Calendar
										x:Name="FilterCalendar"
										FontSize="16"
										SelectionMode="SingleRange"
										AttachedToVisualTree="FilterCalendar_Attached"
										/>
									</Flyout>
								</Button.Flyout>
							</Button>
							<Button
							Background="Transparent"
							BorderThickness="0"
							Width="32" Height="32" Click="ClearDates_Click">

								<Viewbox Stretch="Uniform">
									<Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
										  Stroke="{Binding $parent[Button].Foreground}"
										  StrokeThickness="1" />
								</Viewbox>
							</Button>
						</StackPanel>

						<ItemsControl ItemsSource="{Binding Lessons}"
									  Background="Transparent"
									  BorderThickness="0"
									  Padding="20"
									  >
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Margin="0,10,0,0"
											Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
											CornerRadius="8"
											Padding="16"
											BoxShadow="0 4 8 2 #1A000000"> <Grid ColumnDefinitions="100, 2*, 1.5*, Auto">

												<StackPanel Grid.Column="0" VerticalAlignment="Center">
													<TextBlock Text="DATE" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,4"/>
													<TextBlock Text="{Binding Date}" FontWeight="Bold" FontSize="15" />
												</StackPanel>

												<StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0">
													<TextBlock Text="{Binding CourseName}" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
													<TextBlock Text="{Binding SecondName}" FontSize="13" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
												</StackPanel>

												<StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
													<StackPanel Orientation="Horizontal" Spacing="6">
														<TextBlock Text="{Binding From}" FontWeight="Medium"/>
														<TextBlock Text="-" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
														<TextBlock Text="{Binding To}" FontWeight="Medium"/>
													</StackPanel>

													<StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,4,0,0">
														<TextBlock Text="{Binding Duration, StringFormat='{}{0}'}" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
														<TextBlock Text="{Binding DurataAccadamica, StringFormat='{}({0})'}" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
													</StackPanel>
												</StackPanel>

												<StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16" Margin="16,0,0,0">
													<Button Classes="actionChip danger"
															ToolTip.Tip="Mark as Cancelled"
															Command="{Binding $parent[Window].DataContext.MarkCancelledCommand}"
															CommandParameter="{Binding}"
															IsVisible="{Binding isCancelled}"
															>
														<TextBlock Text="Cancel" MaxWidth="80"/>
													</Button>

													<Button Classes="actionChip warning"
															ToolTip.Tip="Mark as Not Attended"
															Command="{Binding $parent[Window].DataContext.MarkNotAttendedCommand}"
															CommandParameter="{Binding}"
															IsVisible="{Binding isUnattended}"
															>
														<TextBlock Text="Not Attended" MaxWidth="100"/>
													</Button>

													<Button Classes="actionChip success"
															ToolTip.Tip="Mark as Attended"
															Command="{Binding $parent[Window].DataContext.MarkAttendedCommand}"
															CommandParameter="{Binding}"
															IsVisible="{Binding isAttend}"
															>
														<TextBlock Text="Attended" MaxWidth="100"/>
													</Button>
												</StackPanel>

											</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<TabItem Header="Dashboard">
				<ScrollViewer>
					<StackPanel Spacing="20">
						<ItemsControl ItemsSource="{Binding AttendedTime}"
									  Background="Transparent"
									  BorderThickness="0"
									  Padding="20"
									  >
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Expander HorizontalAlignment="Stretch"
											  Margin="0,0,0,12"
											  Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
											  CornerRadius="8">
										<Expander.Header>
											<Grid ColumnDefinitions="2*, Auto">
												<TextBlock Grid.Column="0" Text="{Binding Course.DisplayName}"
														   FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>

												<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
													<TextBlock Text="{Binding Attended, StringFormat='{}{0}'}" FontWeight="Medium"/>
													<TextBlock Text="/" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
													<TextBlock Text="{Binding Total, StringFormat='{}{0}'}" FontWeight="Medium"/>
													<TextBlock Text="{Binding Percentage, StringFormat='{}({0:0.00} %)'}" FontWeight="Light"/>
												</StackPanel>
											</Grid>
										</Expander.Header>

										<StackPanel Margin="10,0,0,0">
											<ItemsControl ItemsSource="{Binding Lessons}"
														  Background="Transparent"
														  BorderThickness="0"
														  Padding="5"
														  >
												<ItemsControl.ItemTemplate>
													<DataTemplate>
														<Border Margin="0,5,0,0"
																Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
																CornerRadius="8"
																Padding="8"
																BoxShadow="0 4 8 2 #1A000000"> <Grid ColumnDefinitions="1*, 1.5*, 1.5*, Auto">

																	<StackPanel Grid.Column="0" VerticalAlignment="Center">
																		<TextBlock Text="{Binding Date}" FontWeight="Bold" FontSize="15" />
																	</StackPanel>

																	<StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
																		<StackPanel Orientation="Horizontal" Spacing="6">
																			<TextBlock Text="{Binding From}" FontWeight="Medium"/>
																			<TextBlock Text="-" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
																			<TextBlock Text="{Binding To}" FontWeight="Medium"/>
																		</StackPanel>
																	</StackPanel>

																						
																	<StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0">
																		<StackPanel Orientation="Horizontal" Spacing="6">
																			<TextBlock Text="{Binding Duration, StringFormat='{}{0}'}" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
																			<TextBlock Text="{Binding DurataAccadamica, StringFormat='{}({0})'}" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
																		</StackPanel>
																	</StackPanel>

																	<StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12" Margin="12,0,0,0">
																		<Button Classes="actionChip danger"
																				IsHitTestVisible="False"
																				ToolTip.Tip="Mark as Cancelled"
																				IsVisible="{Binding isCancelled}"
																				>
																			<TextBlock Text="Cancel" MaxWidth="80"/>
																		</Button>

																		<Button Classes="actionChip warning"
																				IsHitTestVisible="False"
																				ToolTip.Tip="Mark as Not Attended"
																				IsVisible="{Binding isUnattended}"
																				>
																			<TextBlock Text="Not Attended" MaxWidth="100"/>
																		</Button>

																		<Button Classes="actionChip success"
																				IsHitTestVisible="False"
																				ToolTip.Tip="Mark as Attended"
																				IsVisible="{Binding isAttend}"
																				>
																			<TextBlock Text="Attended" MaxWidth="100"/>
																		</Button>
																	</StackPanel>

																</Grid>
														</Border>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
										</StackPanel>
									</Expander>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
		</TabControl>
	</DockPanel>
</Window>